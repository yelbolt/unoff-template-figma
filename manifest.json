{
  "name": "{{ pluginName }}",
  "id": "{{ pluginId }}",
  "api": "1.0.0",
  "editorType": [
    "figma",
    "figjam",
    "dev",
    "buzz"
  ],
  "capabilities": [
    "inspect",
    "vscode"
  ],
  "permissions": [
    "payments",
    "currentuser"
  ],
  "documentAccess": "dynamic-page",
  "networkAccess": {
    "allowedDomains": [
      "https://figma.com",
      "https://*.figma.com",
      "https://*.gravatar.com",
      "https://*.googleusercontent.com",
      "https://*.githubusercontent.com",
      "https://*.wp.com",
      "https://*.supabase.co",
      "https://*.yelbolt.workers.dev",
      "https://*.mixpanel.com",
      "https://asset.brandfetch.io",
      "https://*.sentry.io",
      "https://*.amazonaws.com",
      "https://fonts.googleapis.com",
      "https://fonts.gstatic.com"
    ],
    "devAllowedDomains": [
      "http://localhost:3000",
      "http://localhost:8787",
      "http://localhost:8888",
      "http://localhost:8989"
    ]
  },
  "main": "./dist/plugin.js",
  "ui": "./dist/index.html"
}
